  </action>
  <action name="onclickspotvideo11_controls">
    if(hotspot[spotvideo11].stateVideo == 'playing',
      
      set(hotspot[spotvideo11_playbtn].visible, false);
      set(hotspot[spotvideo11_pausebtn].visible, false);
    ,
      
      set(hotspot[spotvideo11_playbtn].visible, true);
      set(hotspot[spotvideo11_pausebtn].visible, false);
    );
  </action>
  <action name="onclickspotvideo11">
    if (hotspot[spotvideo11].alpha == 0, set(hotspot[spotvideo11].alpha, 1););

    if(%1,
      if(hotspot[spotvideo11].pauseothersounds,
        if(hotspot[spotvideo11].stateVideo == 'playing',
          pauseTourSoundsActions(true,true,true,true,true);

          if (tour_soundson,
            div(volume, tour_soundsvolume, 100);
            if(device.flash,
              set(hotspot[spotvideo11].volume, get(volume));
            ,
              ifnot(device.ios,
                js(kpanotour.Sounds.startVideosSounds(get(volume)));
              );
            );
          );
        ,

          if (tour_soundson,
            if(device.flash,
              set(hotspot[spotvideo11].volume, 0);
            ,
              ifnot(device.ios,
                js(kpanotour.Sounds.stopVideosSounds());
              );
            );
          );
          resumeTourSoundsActions(true,true,true,true,true);
        );
      );
    );
    hotspot[spotvideo11].togglepause();

  </action>

